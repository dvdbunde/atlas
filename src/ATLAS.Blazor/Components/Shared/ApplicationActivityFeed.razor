@namespace ATLAS.Blazor.Components.Shared
@using ATLAS.Application.DTOs

<div class="application-activity-feed">
    @if (Activities.Count == 0)
    {
        <p class="text-muted small">No activity recorded yet.</p>
    }
    else
    {
        @foreach (var entry in Activities)
        {
            <div class="d-flex gap-3 mb-3 align-items-start">
                <div class="mt-1 flex-shrink-0">
                    <span class="badge rounded-circle p-2 d-inline-flex align-items-center justify-content-center"
                          style="width: 32px; height: 32px; @GetIconStyle(entry.ActivityType)">
                        @GetIcon(entry.ActivityType)
                    </span>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-baseline">
                        <strong class="small">@entry.Title</strong>
                        <small class="text-muted ms-2">@entry.Timestamp.ToString("MMM dd, yyyy HH:mm")</small>
                    </div>
                    @if (!string.IsNullOrEmpty(entry.Description))
                    {
                        <p class="mb-0 small text-muted">@entry.Description</p>
                    }
                    @if (!string.IsNullOrEmpty(entry.PerformedBy))
                    {
                        <p class="mb-0 small text-muted">
                            by @entry.PerformedBy
                            @if (!string.IsNullOrEmpty(entry.PerformedByRole))
                            {
                                <span class="text-muted">(@entry.PerformedByRole)</span>
                            }
                        </p>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    [EditorRequired]
    public IReadOnlyList<ApplicationActivityDto> Activities { get; set; } = Array.Empty<ApplicationActivityDto>();

    private static string GetIcon(string activityType) => activityType switch
    {
        "Created"          => "📄",
        "Submitted"        => "📨",
        "Assigned"         => "👤",
        "Approved"         => "✅",
        "Rejected"         => "❌",
        "InfoRequested"    => "ℹ️",
        "Resubmitted"      => "🔄",
        "DocumentUploaded" => "📎",
        _                  => "•"
    };

    private static string GetIconStyle(string activityType) => activityType switch
    {
        "Created"          => "background: #e3f2fd; color: #1565c0;",
        "Submitted"        => "background: #e8f5e9; color: #2e7d32;",
        "Assigned"         => "background: #fff3e0; color: #e65100;",
        "Approved"         => "background: #e8f5e9; color: #2e7d32;",
        "Rejected"         => "background: #ffebee; color: #c62828;",
        "InfoRequested"    => "background: #fff8e1; color: #f9a825;",
        "Resubmitted"      => "background: #e8f5e9; color: #2e7d32;",
        "DocumentUploaded" => "background: #f3e5f5; color: #7b1fa2;",
        _                  => "background: #f5f5f5; color: #616161;"
    };
}