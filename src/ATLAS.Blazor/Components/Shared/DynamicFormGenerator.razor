@using ATLAS.Blazor.FormModel
@using ATLAS.Blazor.Validation
@using ATLAS.Domain.Enums
@using Microsoft.AspNetCore.Components.Forms
@namespace ATLAS.Blazor.Components.Shared

@* 
    DynamicFormGenerator - Reusable component for rendering dynamic form fields
    based on PermitField metadata. Supports all 6 approved field types and
    both Edit and ReadOnly modes.
    
    Embed in any page: ApplicationCreate, ApplicationEdit, ApplicationDetail, etc.
    TODO M6: FileUpload support
*@

<EditForm EditContext="@_editContext">
    <DynamicFieldValidator Fields="@Fields" />

    @foreach (var field in _orderedFields)
    {
        var fieldId = "field-" + field.FieldName;
        var fi = new FieldIdentifier(_editContext.Model, field.FieldName);

        <div class="mb-3">
            <label for="@fieldId" class="form-label">
                @field.Label
                @if (field.IsRequired)
                {
                    <span class="text-danger" aria-label="Required">*</span>
                }
            </label>

            @if (Mode == FormFieldMode.ReadOnly)
            {
                @if (field.Type == FieldType.FileUpload)
                {
                    if (field.UploadedDocuments.Count > 0)
                    {
                        foreach (var doc in field.UploadedDocuments)
                        {
                            <div class="mb-1">
                                <i class="bi bi-file-earmark-text"></i>
                                <span>@doc.FileName</span>
                                <small class="text-muted ms-2">(@(doc.FileSize / 1024)KB)</small>
                                @* D5: Wire download link here *@
                            </div>
                        }
                    }
                    else
                    {
                        <p id="@fieldId" class="form-control-plaintext text-muted">
                            No document uploaded
                        </p>
                    }
                }
                else
                {
                    <p id="@fieldId" class="form-control-plaintext">
                        @(string.IsNullOrEmpty(field.CurrentValue) ? "\u2014" : field.CurrentValue)
                    </p>
                }
            }
            else
            {
                @switch (field.Type)
                {
                    case FieldType.Text:
                        <input id="@fieldId"
                               type="text"
                               class="form-control @(field.HasErrors ? "is-invalid" : "")"
                               value="@field.CurrentValue"
                               @onchange="(ChangeEventArgs e) => HandleValueChanged(field, e.Value?.ToString())"
                               aria-describedby="@(field.HasErrors ? fieldId + "-validation" : null)" />
                        break;

                    case FieldType.MultilineText:
                        <textarea id="@fieldId"
                                  class="form-control @(field.HasErrors ? "is-invalid" : "")"
                                  value="@field.CurrentValue"
                                  @onchange="(ChangeEventArgs e) => HandleValueChanged(field, e.Value?.ToString())"
                                  aria-describedby="@(field.HasErrors ? fieldId + "-validation" : null)">
                        </textarea>
                        break;

                    case FieldType.Number:
                        <input id="@fieldId"
                               type="number"
                               class="form-control @(field.HasErrors ? "is-invalid" : "")"
                               value="@field.CurrentValue"
                               @onchange="(ChangeEventArgs e) => HandleValueChanged(field, e.Value?.ToString())"
                               aria-describedby="@(field.HasErrors ? fieldId + "-validation" : null)" />
                        break;

                    case FieldType.Date:
                        <input id="@fieldId"
                               type="date"
                               class="form-control @(field.HasErrors ? "is-invalid" : "")"
                               value="@field.CurrentValue"
                               @onchange="(ChangeEventArgs e) => HandleValueChanged(field, e.Value?.ToString())"
                               aria-describedby="@(field.HasErrors ? fieldId + "-validation" : null)" />
                        break;

                    case FieldType.Boolean:
                        <div class="form-check">
                            <input id="@fieldId"
                                   type="checkbox"
                                   class="form-check-input @(field.HasErrors ? "is-invalid" : "")"
                                   checked="@string.Equals(field.CurrentValue, "true", StringComparison.OrdinalIgnoreCase)"
                                   @onchange="(ChangeEventArgs e) => HandleValueChanged(field, e.Value?.ToString())"
                                   aria-describedby="@(field.HasErrors ? fieldId + "-validation" : null)" />
                            <label class="form-check-label" for="@fieldId">@field.Label</label>
                        </div>
                        break;

                    case FieldType.Dropdown:                        
                        <select id="@fieldId"
                                class="form-select @(field.HasErrors ? "is-invalid" : "")"
                                value="@field.CurrentValue"
                                @onchange="(ChangeEventArgs e) => HandleValueChanged(field, e.Value?.ToString())"
                                aria-describedby="@(field.HasErrors ? fieldId + "-validation" : null)">
                            <option value="">@("Select " + field.Label.ToLower() + "...")</option>
                            @foreach (var option in field.Options)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>                        
                        break;

                    case FieldType.FileUpload:
                        <div class="file-upload-wrapper">
                            @if (AllowFileUpload)
                            {
                                <InputFile id="@fieldId"
                                       class="@(field.HasErrors ? "form-control is-invalid" : "form-control")"
                                       OnChange="@((InputFileChangeEventArgs e) => HandleFileSelected(field, e))"
                                       disabled="@field.IsUploading"
                                       aria-describedby="@(field.HasErrors ? fieldId + "-validation" : null)" />

                                @if (field.IsUploading)
                                {
                                    <div class="mt-1">
                                        <small class="text-muted">
                                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                            Uploading...
                                        </small>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(field.SelectedFileName))
                                {
                                    <div class="mt-1">
                                        <small class="text-muted">
                                            <i class="bi bi-file-earmark"></i>
                                            @field.SelectedFileName
                                            @if (field.MaxFileSizeBytes.HasValue)
                                            {
                                                <span class="ms-2">(Max: @(field.MaxFileSizeBytes.Value / (1024 * 1024))MB)</span>
                                            }
                                        </small>
                                    </div>
                                }
                                else
                                {
                                    <div class="mt-1">
                                        <small class="text-muted">
                                            @if (!string.IsNullOrEmpty(field.AllowedExtensions))
                                            {
                                                <span>Accepted: @field.AllowedExtensions</span>
                                            }
                                            @if (field.MaxFileSizeBytes.HasValue)
                                            {
                                                <span class="ms-2">Max @(field.MaxFileSizeBytes.Value / (1024 * 1024))MB</span>
                                            }
                                        </small>
                                    </div>
                                }

                                @if (field.UploadFailed)
                                {
                                    <div class="mt-1 text-danger">
                                        <small>
                                            <i class="bi bi-exclamation-triangle"></i>
                                            @field.UploadErrorMessage
                                        </small>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="mt-1">
                                    <small class="text-muted">
                                        @if (!string.IsNullOrEmpty(field.AllowedExtensions))
                                        {
                                            <span>Accepted: @field.AllowedExtensions</span>
                                        }
                                        @if (field.MaxFileSizeBytes.HasValue)
                                        {
                                            <span class="ms-2">Max @(field.MaxFileSizeBytes.Value / (1024 * 1024))MB</span>
                                        }
                                    </small>
                                </div>
                            }

                            @* Document requirement status indicator *@
                            @if (field.Type == FieldType.FileUpload)
                            {
                                <div class="mt-1">
                                    @if (field.IsDocumentRequirementSatisfied)
                                    {
                                        <small class="text-success">
                                            <i class="bi bi-check-circle-fill"></i>
                                            @(field.IsRequired ? "Required document uploaded" : "Optional document")
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-warning">
                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                            Required document not yet uploaded
                                        </small>
                                    }
                                </div>
                            }

                            @* Uploaded documents list — shown in both modes *@
                            @if (field.UploadedDocuments.Count > 0)
                            {
                                <div class="mt-2">
                                    <small class="text-muted fw-bold">
                                        @(field.UploadedDocuments.Count) document(s):
                                    </small>
                                    @foreach (var doc in field.UploadedDocuments)
                                    {
                                        <div class="d-flex align-items-center ms-2 mt-1">
                                            <small class="flex-grow-1">
                                                <i class="bi bi-file-earmark-check text-success"></i>
                                                <strong>@doc.FileName</strong>
                                                <span class="text-muted mx-1">|</span>
                                                @(doc.FileSize / 1024)KB
                                                @if (doc.UploadedDate != default)
                                                {
                                                    <span class="text-muted mx-1">|</span>
                                                    @doc.UploadedDate.ToString("g")
                                                }
                                            </small>

                                            @if (AllowFileUpload && Mode != FormFieldMode.ReadOnly)
                                            {
                                                <button type="button"
                                                        class="btn btn-outline-danger btn-sm ms-2"
                                                        disabled="@(field.IsDeleting || field.IsUploading)"
                                                        @onclick="() => OnDocumentDeleted.InvokeAsync((field, doc.Id))"
                                                        aria-label="Delete @doc.FileName">
                                                    @if (field.IsDeleting)
                                                    {
                                                        <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-trash"></i>
                                                    }
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (field.DeleteFailed && !string.IsNullOrEmpty(field.DeleteErrorMessage))
                            {
                                <div class="mt-1 text-danger">
                                    <small>
                                        <i class="bi bi-exclamation-triangle"></i>
                                        @field.DeleteErrorMessage
                                    </small>
                                </div>
                            }
                        </div>
                        break;

                    default:
                        <p class="text-muted">Unsupported field type: @field.Type</p>
                        break;
                }

                @if (field.HasErrors)
                {
                    <div id="@(fieldId + "-validation")" class="invalid-feedback" role="alert" aria-live="polite">
                        @foreach (var error in field.Errors)
                        {
                            <span>@error</span>
                        }
                    </div>
                }
            }
        </div>
    }
     @ChildContent
</EditForm>


