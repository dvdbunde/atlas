@namespace ATLAS.Blazor.Components.Shared
@using ATLAS.Blazor.ViewModels

<div class="card h-100 shadow-sm">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title mb-0 text-truncate" title="@Application.PermitTypeName">@Application.PermitTypeName</h5>
            <StatusBadge Status="@Application.Status" />
        </div>

        <p class="text-muted small mb-2">@Application.ApplicationNumber</p>

        <dl class="row small mb-2">
            <dt class="col-5 text-muted">Citizen</dt>
            <dd class="col-7 text-truncate" title="@Application.CitizenName">@Application.CitizenName</dd>

            <dt class="col-5 text-muted">Submitted</dt>
            <dd class="col-7">@Application.SubmittedDateDisplay</dd>

            <dt class="col-5 text-muted">Updated</dt>
            <dd class="col-7">@Application.LastUpdatedDisplay</dd>

            <dt class="col-5 text-muted">Officer</dt>
            <dd class="col-7 text-truncate" title="@Application.AssignedOfficerDisplay">@Application.AssignedOfficerDisplay</dd>
        </dl>

        <div class="mb-3">
            <span class="badge bg-light text-dark border">
                @Application.DocumentCount document(s)
            </span>
            @if (Application.AllRequiredDocumentsUploaded)
            {
                <span class="badge bg-success">All required docs</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Docs incomplete</span>
            }
        </div>

        <div class="mt-auto">
            <a href="@Application.NavigationUrl" class="btn btn-primary w-100"
               aria-label="@Application.ActionLabel for @Application.ApplicationNumber">
                @Application.ActionLabel
            </a>
        </div>
    </div>
</div>