@page "/applications/confirmation/{Id:guid}"
@attribute [Authorize(Roles = "Citizen")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization

<PageTitle>Application Submitted</PageTitle>

<div class="container mt-4">
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Confirmation</li>
        </ol>
    </nav>
    @if (_viewModel.IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5" role="status">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <span class="ms-3">Loading confirmation...</span>
        </div>
    }
    else if (_viewModel.HasError)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Something went wrong</h4>
            <p>@_viewModel.ErrorMessage</p>
            <hr>
            <a href="/dashboard" class="btn btn-outline-primary">Go to Dashboard</a>
        </div>
    }
    else if (_viewModel.IsLoaded)
    {
        <div class="text-center mb-4">
            <div class="display-1 text-success mb-3" aria-hidden="true">&#10003;</div>
            <h1 class="mb-2">Application Submitted Successfully</h1>
            <p class="lead text-muted">Your permit application has been received.</p>
        </div>

        <div class="card shadow-sm mx-auto" style="max-width: 600px;">
            <div class="card-body">
                <h5 class="card-title mb-3">Application Summary</h5>

                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="fw-semibold text-muted">Application Number</td>
                            <td class="text-end">@_viewModel.ApplicationNumber</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted">Permit Type</td>
                            <td class="text-end">@_viewModel.PermitTypeName</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted">Status</td>
                            <td class="text-end"><StatusBadge Status="@_viewModel.Status" /></td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted">Submitted</td>
                            <td class="text-end">@_viewModel.SubmittedDateDisplay</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="text-center mt-4">
            <a href="/applications/@_viewModel.ApplicationId" class="btn btn-primary btn-lg me-2">
                View Application
            </a>
            <a href="/dashboard" class="btn btn-outline-primary btn-lg">
                Go to Dashboard
            </a>
        </div>
    }
</div>