@page "/"

@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        // Unauthenticated users go to the Entra ID sign-in flow, mirroring
        // RedirectToLogin used by the router's NotAuthorized branch.
        if (user.Identity is not { IsAuthenticated: true })
        {
            Navigation.NavigateTo("MicrosoftIdentity/Account/SignIn", forceLoad: true);
            return;
        }

        // Authenticated users land on the dashboard matching their role.
        if (user.IsInRole("Admin"))
        {
            Navigation.NavigateTo("admin");
        }
        else if (user.IsInRole("Officer"))
        {
            Navigation.NavigateTo("officer/dashboard");
        }
        else if (user.IsInRole("Citizen"))
        {
            Navigation.NavigateTo("dashboard");
        }
        else
        {
            // Authenticated but without a recognized role: nothing to show.
            Navigation.NavigateTo("not-found");
        }
    }
}