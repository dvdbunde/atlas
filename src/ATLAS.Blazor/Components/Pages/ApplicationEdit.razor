@page "/applications/edit/{Id:guid}"
@attribute [Authorize(Roles = "Citizen")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using ATLAS.Domain.Enums

<PageTitle>@("Edit " + (_viewModel.ApplicationNumber ?? "Application"))</PageTitle>

<div class="container mt-4">
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit @_viewModel.ApplicationNumber</li>
        </ol>
    </nav>
    @if (_viewModel.IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5" role="status">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <span class="ms-3">Loading application...</span>
        </div>
    }
    else if (_viewModel.HasError)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Something went wrong</h4>
            <p>@_viewModel.ErrorMessage</p>
            <hr>
            <button class="btn btn-outline-danger" @onclick="LoadApplication">
                Try Again
            </button>
        </div>
    }
    else if (_viewModel.IsLoaded)
    {
        <h1 class="mb-2">@_viewModel.PermitName</h1>
        <p class="text-muted mb-3">@_viewModel.PermitDescription</p>
        <p class="text-muted small mb-4">
            Application: <strong>@_viewModel.ApplicationNumber</strong>
            &middot; Status: <StatusBadge Status="@_viewModel.Status" />
        </p>

        @if (_viewModel.CreatedSuccess)
        {
            <div class="alert alert-success" role="alert">
                <h4 class="alert-heading">Draft created successfully</h4>
                <p>Your draft application has been created. You can now continue editing, add documents, or submit the application.</p>
                <button class="btn btn-outline-success" @onclick="DismissCreatedSuccess">
                    Continue Editing
                </button>
            </div>
        }

        @if (_viewModel.SaveSuccess)
        {
            <div class="alert alert-success" role="alert">
                <h4 class="alert-heading">Changes saved</h4>
                <p>Your draft application has been updated successfully.</p>
                <button class="btn btn-outline-success" @onclick="DismissSuccess">
                    Continue Editing
                </button>
            </div>
        }

        @* Document section — only show when the permit type has FileUpload fields *@
        @if (_viewModel.Fields.Any(f => f.Type == FieldType.FileUpload))
        {
            <hr class="my-4" />
            <h2 class="h4 mb-1">Supporting Documents</h2>
            <p class="text-muted small mb-3">
                Upload the required documents for your application.
                Required documents must be uploaded before you can submit.
            </p>
        }

        <DynamicFormGenerator @ref="_dynamicForm"
                              Fields="@_viewModel.Fields"
                              Mode="FormFieldMode.Edit" 
                              AllowFileUpload="true"
                              OnFileSelected="@((DynamicFormFieldViewModel f) => HandleFileSelected(f))"
                              OnDocumentDeleted="@(args => HandleDocumentDeleted(args))">
            <div class="mt-4">
                <button type="button"
                        class="btn btn-primary btn-lg"
                        disabled="@_viewModel.IsSaving"
                        @onclick="SaveDraft">
                    @if (_viewModel.IsSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Changes</span>
                    }
                </button>
            </div>
        </DynamicFormGenerator>

        @* Submit button — only when form is valid *@
        <div class="mt-3 d-flex gap-2">
            <button type="button"
                    class="btn btn-success btn-lg"
                    disabled="@(_viewModel.IsSubmitting || _viewModel.Fields.Any(f => f.HasErrors))"
                    aria-label="Submit application"
                    @onclick="SubmitApplication">
                @if (_viewModel.IsSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                    <span>Submitting...</span>
                }
                else
                {
                    <span>Submit Application</span>
                }
            </button>
        </div>
        
        @* O5: Information request banner *@
        @if (_viewModel.IsInfoRequested)
        {
            <div class="alert alert-info mt-4" role="alert">
                <h5 class="alert-heading">Additional Information Required</h5>
                @if (!string.IsNullOrEmpty(_viewModel.InfoRequestOfficerName))
                {
                    <p class="mb-1"><strong>Requested by:</strong> @_viewModel.InfoRequestOfficerName</p>
                }
                @if (!string.IsNullOrEmpty(_viewModel.InfoRequestDateDisplay))
                {
                    <p class="mb-1"><strong>Requested on:</strong> @_viewModel.InfoRequestDateDisplay</p>
                }
                @if (!string.IsNullOrEmpty(_viewModel.InfoRequestMessage))
                {
                    <p class="mb-0"><strong>Request:</strong> @_viewModel.InfoRequestMessage</p>
                }
            </div>
        }
    
        @* O5: Resubmit button — only for InfoRequested applications *@
        @if (_viewModel.IsInfoRequested)
        {
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-primary"
                        @onclick="ResubmitApplication"
                        disabled="@(_viewModel.IsResubmitting || _viewModel.Fields.Any(f => f.HasErrors))">
                    @if (_viewModel.IsResubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                    }
                    Resubmit Application
                </button>
            </div>
    
            @if (_viewModel.IsResubmitting)
            {
                <div class="mt-3 text-muted" role="status">Resubmitting your application...</div>
            }
    
            @if (_viewModel.ResubmitHasError)
            {
                <div class="alert alert-danger mt-3" role="alert">
                    @_viewModel.ResubmitErrorMessage
                </div>
            }
    
            @if (_viewModel.ResubmitSuccess)
            {
                <div class="alert alert-success mt-3" role="alert">
                    Your application has been resubmitted successfully. It will be reviewed by the officer.
                </div>
            }
        }

        @if (_viewModel.IsSaving)
        {
            <div class="mt-3 text-muted" role="status">Saving your changes...</div>
        }

        @if (_viewModel.IsSubmitting)
        {
            <div class="mt-3 text-muted" role="status">Submitting your application...</div>
        }

        @if (_viewModel.SubmitHasError)
        {
            <div class="alert alert-danger mt-3" role="alert" @ref="_submitErrorAlert">
                @_viewModel.SubmitErrorMessage
                <hr>
                <a href="/dashboard" class="btn btn-outline-danger btn-sm">Go to Dashboard</a>
            </div>
        }
    }
</div>