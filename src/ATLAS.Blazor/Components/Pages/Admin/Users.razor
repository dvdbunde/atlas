@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using ATLAS.Blazor.Components.Shared.Admin
@using ATLAS.Domain.Entities

<PageTitle>Users</PageTitle>

<div class="container mt-4">
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin">Administration</a></li>
            <li class="breadcrumb-item active" aria-current="page">Users</li>
        </ol>
    </nav>

    <PageHeader Title="Users"
                Description="Read-only directory of ATLAS users synchronized from Microsoft Entra ID." />

    @if (_viewModel.IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5" role="status">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <span class="ms-3">Loading users...</span>
        </div>
    }
    else if (_viewModel.HasError)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Something went wrong</h4>
            <p>@_viewModel.ErrorMessage</p>
            <hr />
            <button class="btn btn-outline-danger" @onclick="LoadUsers">Try Again</button>
        </div>
    }
    else if (_viewModel.IsEmpty)
    {
        <EmptyState Title="No users found"
                    Message="No users match the current filters. Try clearing the search or role filter." />
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-6">
                <input type="search" class="form-control" placeholder="Search by name or email"
                       value="@_viewModel.SearchTerm" @oninput="OnSearchInput" aria-label="Search users" />
            </div>
            <div class="col-12 col-md-3">
                <select class="form-select" @onchange="OnRoleFilterChanged" aria-label="Filter by role">
                    <option value="">All roles</option>
                    <option value="@((int)UserRole.Citizen)">Citizen</option>
                    <option value="@((int)UserRole.Officer)">Officer</option>
                    <option value="@((int)UserRole.Admin)">Admin</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <select class="form-select" @onchange="OnSortChanged" aria-label="Sort users">
                    <option value="NameAsc">Name (A-Z)</option>
                    <option value="NameDesc">Name (Z-A)</option>
                    <option value="EmailAsc">Email (A-Z)</option>
                    <option value="EmailDesc">Email (Z-A)</option>
                    <option value="LastLoginDesc">Last login (newest)</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Email</th>
                        <th scope="col">Role</th>
                        <th scope="col">Last Login</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _viewModel.Items)
                    {
                        <tr>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td><span class="badge text-bg-info">@user.Role</span></td>
                            <td>@(user.LastLoginDate?.ToLocalTime().ToString("g") ?? "Never")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="@($"/admin/users/{user.Id}")">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_viewModel.TotalPages > 1)
        {
            <nav aria-label="User list pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(_viewModel.PageNumber <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(_viewModel.PageNumber - 1)" disabled="@(_viewModel.PageNumber <= 1)">Previous</button>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page @_viewModel.PageNumber of @_viewModel.TotalPages</span>
                    </li>
                    <li class="page-item @(_viewModel.PageNumber >= _viewModel.TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(_viewModel.PageNumber + 1)" disabled="@(_viewModel.PageNumber >= _viewModel.TotalPages)">Next</button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
