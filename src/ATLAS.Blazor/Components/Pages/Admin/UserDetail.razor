@page "/admin/users/{Id:guid}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using ATLAS.Blazor.Components.Shared.Admin

<PageTitle>User Details</PageTitle>

<div class="container mt-4">
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin">Administration</a></li>
            <li class="breadcrumb-item"><a href="/admin/users">Users</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    @if (_viewModel.IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5" role="status">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <span class="ms-3">Loading user...</span>
        </div>
    }
    else if (_viewModel.HasError)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Something went wrong</h4>
            <p>@_viewModel.ErrorMessage</p>
            <hr />
            <button class="btn btn-outline-danger" @onclick="LoadUser">Try Again</button>
        </div>
    }
    else if (_viewModel.NotFound)
    {
        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading">User not found</h4>
            <p>The requested user does not exist or has not signed in yet.</p>
            <button class="btn btn-outline-secondary" @onclick="BackToList">Back to list</button>
        </div>
    }
    else if (_viewModel.User is not null)
    {
        var u = _viewModel.User;
        <PageHeader Title="@u.FullName"
                    Description="@u.Email" />

        <div class="alert alert-info small mb-3" role="alert">
            Identity and role are managed in Microsoft Entra ID and synchronized read-only into ATLAS.
            Changes to role or status must be made in Entra ID.
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-header">Profile</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Name</dt>
                            <dd class="col-sm-8">@u.FullName</dd>
                            <dt class="col-sm-4">First name</dt>
                            <dd class="col-sm-8">@u.FirstName</dd>
                            <dt class="col-sm-4">Last name</dt>
                            <dd class="col-sm-8">@u.LastName</dd>
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">@u.Email</dd>
                            <dt class="col-sm-4">Role</dt>
                            <dd class="col-sm-8"><span class="badge text-bg-info">@u.Role</span></dd>
                            <dt class="col-sm-4">Last login</dt>
                            <dd class="col-sm-8">@(u.LastLoginDate?.ToLocalTime().ToString("g") ?? "Never")</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-header">Recent Activity</div>
                    <div class="card-body">
                        @if (u.RecentAuditEntries.Count == 0)
                        {
                            <p class="text-muted mb-0">No recorded activity for this user.</p>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var entry in u.RecentAuditEntries)
                                {
                                    <li class="list-group-item">
                                        <div class="d-flex justify-content-between">
                                            <span><strong>@entry.Action</strong> <span class="text-muted">(@entry.EntityType)</span></span>
                                            <small class="text-muted">@entry.Timestamp.ToLocalTime().ToString("g")</small>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(entry.Details))
                                        {
                                            <div class="small text-muted">@entry.Details</div>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-outline-secondary" @onclick="BackToList">Back to list</button>
        </div>
    }
</div>
