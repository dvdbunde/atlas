@page "/admin/permit-types/new"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using ATLAS.Blazor.Components.Shared.Admin

<PageTitle>Create Permit Type</PageTitle>

<div class="container mt-4">
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin">Administration</a></li>
            <li class="breadcrumb-item"><a href="/admin/permit-types">Permit Types</a></li>
            <li class="breadcrumb-item active" aria-current="page">New</li>
        </ol>
    </nav>

    <PageHeader Title="Create Permit Type"
                Description="Provide the minimum information to create a new permit type." />

    @if (_viewModel.HasError)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Unable to create</h4>
            <p>@_viewModel.ErrorMessage</p>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label" for="ptc-name">Name</label>
                <input id="ptc-name" class="form-control" type="text"
                       @bind="_viewModel.Name" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="ptc-description">Description</label>
                <textarea id="ptc-description" class="form-control"
                          @bind="_viewModel.Description"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label" for="ptc-fee">Fee</label>
                <input id="ptc-fee" class="form-control" type="number" step="0.01" min="0"
                       @bind="_viewModel.Fee" />
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" @onclick="Create" disabled="@_viewModel.IsSaving">
            @if (_viewModel.IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Create
        </button>
        <button class="btn btn-outline-secondary" @onclick="Cancel" disabled="@_viewModel.IsSaving">
            Cancel
        </button>
    </div>
</div>
