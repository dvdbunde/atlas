@page "/applications/create/{PermitTypeId:guid}"
@attribute [Authorize(Roles = "Citizen")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization

<PageTitle>@(_viewModel.PermitName ?? "New Application")</PageTitle>

<div class="container mt-4">
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/permits">Permits</a></li>
            <li class="breadcrumb-item active" aria-current="page">New Application</li>
        </ol>
    </nav>
    @if (_viewModel.IsLoading)
    {
        <div class="d-flex justify-content-center align-items-center py-5" role="status">
            <div class="spinner-border text-primary" aria-hidden="true"></div>
            <span class="ms-3">Loading permit type...</span>
        </div>
    }
    else if (_viewModel.HasError)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Something went wrong</h4>
            <p>@_viewModel.ErrorMessage</p>
            <hr>
            <button class="btn btn-outline-danger" @onclick="LoadPermitType">
                Try Again
            </button>
            <a href="/dashboard" class="btn btn-outline-primary ms-2">Go to Dashboard</a>
        </div>
    }
    else if (_viewModel.IsLoaded)
    {
        <h1 class="mb-2">@_viewModel.PermitName</h1>
        <p class="text-muted mb-4">@_viewModel.PermitDescription</p>

        @if (_viewModel.SaveSuccess)
        {
            <div class="alert alert-success" role="alert">
                <h4 class="alert-heading">Draft saved</h4>
                <p>Your application has been saved as a draft.</p>
                <a href="/applications/edit/@_viewModel.CreatedApplicationId"
                   class="btn btn-primary">
                    Continue Editing
                </a>
            </div>
        }
        else
        {
            <DynamicFormGenerator @ref="_dynamicForm" 
                      Fields="@_viewModel.Fields" 
                      Mode="FormFieldMode.Edit">
                <div class="mt-4">
                    <button type="button"
                            class="btn btn-primary btn-lg"
                            disabled="@_viewModel.IsSaving"
                            @onclick="SaveDraft">
                        @if (_viewModel.IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Save Draft</span>
                        }
                    </button>
                </div>
            </DynamicFormGenerator>

            @if (_viewModel.IsSaving)
            {
                <div class="mt-3 text-muted" role="status">Saving your draft application...</div>
            }
        }
    }
</div>